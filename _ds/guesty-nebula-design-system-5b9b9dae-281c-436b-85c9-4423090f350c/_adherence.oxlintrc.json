{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Figtree|Noto Serif Georgian))/i]",
        "message": "Font not provided by the design system. Available: Figtree, Noto Serif Georgian."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dismissible|showIcon|icon|defaultOpen|open|onOpenChange|children|style|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: variant, dismissible, showIcon, icon, defaultOpen, open, onOpenChange, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|information|success|warning|critical)$/]",
        "message": "<Alert> variant must be one of 'neutral' | 'information' | 'success' | 'warning' | 'critical'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|style|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, children, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|secondary|outline|destructive)$/]",
        "message": "<Badge> variant must be one of 'default' | 'secondary' | 'outline' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|isLoading|icon|children|disabled|onClick|style|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, isLoading, icon, children, disabled, onClick, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|destructive|secondary|plain|plain-primary)$/]",
        "message": "<Button> variant must be one of 'default' | 'destructive' | 'secondary' | 'plain' | 'plain-primary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|sm|lg|icon|icon-sm)$/]",
        "message": "<Button> size must be one of 'default' | 'sm' | 'lg' | 'icon' | 'icon-sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|style|className|onClick|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, style, className, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|prefix|suffix|showClearButton|placeholder|disabled|value|defaultValue|onChange|type|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: size, prefix, suffix, showClearButton, placeholder, disabled, value, defaultValue, onChange, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:base|sm)$/]",
        "message": "<Input> size must be one of 'base' | 'sm'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
